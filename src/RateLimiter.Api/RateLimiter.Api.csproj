	  <PackageReference Include="NLog" Version="6.1.4" />
	  <PackageReference Include="NLog.Extensions.Logging" Version="6.1.4" />
	  <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="8.0.11" />
	  <PackageReference Include="StackExchange.Redis" Version="3.0.17" />
	  <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
	  <PackageReference Include="Testcontainers.Redis" Version="4.13.0" />
	  <PackageReference Include="xunit" Version="2.9.2" />
