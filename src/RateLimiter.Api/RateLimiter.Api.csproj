		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
	  </PackageReference>
    
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\RateLimiter.Domain\RateLimiter.Domain.csproj" />
    <ProjectReference Include="..\RateLimiter.Infrastructure\RateLimiter.Infrastructure.csproj" />
  </ItemGroup>

</Project>
